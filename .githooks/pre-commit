#!/bin/bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

STAGED_FILES=()
while IFS= read -r file; do
    STAGED_FILES+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ "${#STAGED_FILES[@]}" -eq 0 ]]; then
    exit 0
fi

TS_FILES=()
SWIFT_FILES=()

for file in "${STAGED_FILES[@]}"; do
    case "$file" in
        mcp-server/src/*.ts)
            TS_FILES+=("$file")
            ;;
        Operator/Sources/*.swift|Operator/Sources/**/*.swift|Operator/Tests/*.swift|Operator/Tests/**/*.swift)
            SWIFT_FILES+=("$file")
            ;;
    esac
done

if [[ "${#TS_FILES[@]}" -gt 0 ]]; then
    echo "=== Pre-commit: MCP Server ==="
    pushd "$ROOT_DIR/mcp-server" >/dev/null

    REL_TS_FILES=()
    for file in "${TS_FILES[@]}"; do
        REL_TS_FILES+=("${file#mcp-server/}")
    done

    echo "  TypeScript typecheck..."
    npx tsc --noEmit --pretty false

    echo "  ESLint (${#REL_TS_FILES[@]} file(s))..."
    npx eslint "${REL_TS_FILES[@]}"

    echo "  Prettier (${#REL_TS_FILES[@]} file(s))..."
    npx prettier --check "${REL_TS_FILES[@]}"

    popd >/dev/null
fi

if [[ "${#SWIFT_FILES[@]}" -gt 0 ]]; then
    echo "=== Pre-commit: Swift ==="
    pushd "$ROOT_DIR/Operator" >/dev/null

    REL_SWIFT_FILES=()
    for file in "${SWIFT_FILES[@]}"; do
        REL_SWIFT_FILES+=("${file#Operator/}")
    done

    echo "  SwiftLint (${#REL_SWIFT_FILES[@]} file(s))..."
    for file in "${REL_SWIFT_FILES[@]}"; do
        swiftlint lint --strict "$file"
    done

    echo "  swift-format (${#REL_SWIFT_FILES[@]} file(s))..."
    swift-format lint --strict "${REL_SWIFT_FILES[@]}"

    popd >/dev/null
fi

echo "=== Pre-commit checks passed ==="
