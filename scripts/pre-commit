#!/bin/bash
set -euo pipefail

# Pre-commit hook: lint Swift files with --strict (warnings = errors), matching CI.
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

ROOT_DIR="$(git rev-parse --show-toplevel)"

# Only lint if Swift files are staged
SWIFT_STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift' || true)
if [ -z "$SWIFT_STAGED" ]; then
    exit 0
fi

echo "==> Pre-commit: SwiftLint (--strict)"
cd "$ROOT_DIR/Operator"
swiftlint lint --strict --quiet

echo "==> Pre-commit: swift-format (--strict)"
find Sources Tests -name '*.swift' \
  ! -path 'Sources/Tokenizer/*' \
  ! -path 'Sources/CleanupCLI/*' \
  -print0 | xargs -0 swift-format lint --strict

echo "==> Pre-commit: lint passed"
