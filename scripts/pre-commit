#!/bin/bash
set -euo pipefail

# Pre-commit hook: lint only STAGED Swift files with --strict (warnings = errors).
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

ROOT_DIR="$(git rev-parse --show-toplevel)"

# Only lint if Swift files are staged
SWIFT_STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift' || true)
if [ -z "$SWIFT_STAGED" ]; then
    exit 0
fi

cd "$ROOT_DIR/Operator"

# Build list of staged Swift files (relative to Operator/), excluding vendored code
STAGED_SWIFT=()
while IFS= read -r f; do
  rel="${f#Operator/}"
  case "$rel" in
    Sources/Tokenizer/*|Sources/QwenTokenizerRust/*) continue ;;
  esac
  [ -f "$rel" ] && STAGED_SWIFT+=("$rel")
done <<< "$SWIFT_STAGED"

if [ ${#STAGED_SWIFT[@]} -eq 0 ]; then
    echo "==> Pre-commit: no lintable Swift files staged"
    exit 0
fi

# Auto-fix staged files, then re-stage
echo "==> Pre-commit: auto-fixing with SwiftLint and swift-format"
swiftlint lint --fix --quiet "${STAGED_SWIFT[@]}" 2>/dev/null || true
swift-format format --in-place "${STAGED_SWIFT[@]}" 2>/dev/null || true

# Re-stage any auto-fixed files
cd "$ROOT_DIR"
echo "$SWIFT_STAGED" | while IFS= read -r f; do
  [ -f "$f" ] && git add "$f"
done

# Now lint strictly — only staged files
cd "$ROOT_DIR/Operator"
echo "==> Pre-commit: SwiftLint (--strict)"
swiftlint lint --strict --quiet "${STAGED_SWIFT[@]}"

echo "==> Pre-commit: swift-format (--strict)"
swift-format lint --strict "${STAGED_SWIFT[@]}"

echo "==> Pre-commit: lint passed"
